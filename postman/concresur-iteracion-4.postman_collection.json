            "logistica",
            "pedidos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.data && jsonData.data.length > 0) {",
              "        pm.collectionVariables.set('pedido_logistico_id', jsonData.data[0].id);",
              "    }",
              "}"
            ]
          }
        }
      ]
    },
